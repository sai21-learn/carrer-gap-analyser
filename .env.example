# --- Feature Toggles ---
USE_MOCK_DATA=false
ENABLE_BERT=false

# --- Database & Redis ---
# SQLite: sqlite:///./career_gap.db
# PostgreSQL: postgresql://user:password@localhost:5432/career_gap
DATABASE_URL=sqlite:///./career_gap.db
REDIS_URL=redis://localhost:6379/0

# --- Authentication (Clerk) ---
# Get these from your Clerk Dashboard
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json

# --- Adzuna API (Job Scraping) ---
# Register at developer.adzuna.com
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key
ADZUNA_COUNTRY=in
ADZUNA_DEFAULT_LOCATION=India

# --- Scraping & Performance ---
MAX_JOBS_PER_PLATFORM=20
REQUEST_DELAY_SECONDS=2
SCRAPE_TIMEOUT_SECONDS=10
